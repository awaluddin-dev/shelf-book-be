generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "user"]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
  @@schema("user")
}

// ------------------------------------
// PORTFOLIO MODELS
// ------------------------------------

model PortfolioStatus {
  id     String @id @default("status_1") // Single row enforced
  status String @default("busy")

  @@map("portfolio_status")
  @@schema("public")
}

model HeroConfig {
  id           String @id @default("hero_1")
  name         String?
  role         String?
  availability String?
  openForWork  Boolean? @default(true)
  config       Json?    // For any flexible structure

  @@map("hero_config")
  @@schema("public")
}

model Metric {
  id    String @id @default(uuid())
  value String
  label String

  @@map("metrics")
  @@schema("public")
}

model Testimonial {
  id          String  @id @default(uuid())
  name        String
  position    String
  avatar      String?
  text        String
  highlighted Boolean @default(false)
  project     String?

  @@map("testimonials")
  @@schema("public")
}

model WorkExperience {
  id          String   @id @default(uuid())
  role        String
  company     String
  type        String
  startDate   String
  endDate     String?
  current     Boolean  @default(false)
  description String
  stack       String[]
  logo        String?

  @@map("work_experiences")
  @@schema("public")
}

model CurrentFocus {
  id          String  @id @default(uuid())
  title       String
  icon        String
  description String
  link        String?
  linkText    String?

  @@map("current_focus")
  @@schema("public")
}

model Proficiency {
  id     String             @id @default(uuid())
  title  String
  skills ProficiencySkill[]

  @@map("proficiencies")
  @@schema("public")
}

model ProficiencySkill {
  id            String      @id @default(uuid())
  name          String
  subtext       String
  status        String
  proficiencyId String
  proficiency   Proficiency @relation(fields: [proficiencyId], references: [id], onDelete: Cascade)

  @@map("proficiency_skills")
  @@schema("public")
}

model Skill {
  id       String  @id @default(uuid())
  title    String
  category String
  level    String
  x        Int     @default(0)
  y        Int     @default(0)
  icon     String?

  @@map("skills")
  @@schema("public")
}

model Roadmap {
  id          String   @id @default(uuid())
  tech        String
  quarter     String
  status      String
  icon        String?
  description String
  depth       String?
  topics      String[]
  projects    String[]

  @@map("roadmaps")
  @@schema("public")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  image       String?
  tags        String[]
  repo        String?
  demo        String?
  highlights  String[]
  role        String?
  duration    String?
  slug        String?  @unique

  @@map("projects")
  @@schema("public")
}