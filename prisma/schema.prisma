generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "user"]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
  @@schema("user")
}

// ------------------------------------
// PORTFOLIO MODELS
// ------------------------------------

model PortfolioStatus {
  id     String @id @default("status_1") // Single row enforced
  status String @default("busy")

  @@map("portfolio_status")
  @@schema("public")
}

model HeroConfig {
  id           String @id @default("hero_1")
  name         String?
  role         String?
  availability String?
  openForWork  Boolean? @default(true)
  
  // New explicitly typed fields
  expertise    String?
  grit         String?
  service      String?
  
  config       Json?    // Kept for any future untyped fields

  @@map("hero_config")
  @@schema("public")
}

model Metric {
  id    String @id @default(uuid())
  value String
  label String

  @@map("metrics")
  @@schema("public")
}

model Testimonial {
  id           String  @id @default(uuid())
  name         String
  role         String
  company      String
  relationship String
  testimonial  String

  @@map("testimonials")
  @@schema("public")
}

model WorkExperience {
  id          String @id @default(uuid())
  title       String
  company     String
  period      String
  description String
  type        String
  level       String

  @@map("work_experiences")
  @@schema("public")
}

model CurrentFocus {
  id          String  @id @default(uuid())
  title       String
  icon        String
  description String
  link        String?
  linkText    String?

  @@map("current_focus")
  @@schema("public")
}

model Proficiency {
  id     String             @id @default(uuid())
  title  String
  skills ProficiencySkill[]

  @@map("proficiencies")
  @@schema("public")
}

model ProficiencySkill {
  id            String      @id @default(uuid())
  name          String
  subtext       String
  status        String
  proficiencyId String
  proficiency   Proficiency @relation(fields: [proficiencyId], references: [id], onDelete: Cascade)

  @@map("proficiency_skills")
  @@schema("public")
}

model Skill {
  id          String  @id @default(uuid())
  title       String
  category    String
  level       String
  details     String
  x           Int     @default(0)
  y           Int     @default(0)
  connections String?

  @@map("skills")
  @@schema("public")
}

model Roadmap {
  id          String  @id @default(uuid())
  tech        String
  quarter     String
  status      String
  icon        String?
  description String
  depth       String?
  topics      String
  projects    String

  @@map("roadmaps")
  @@schema("public")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  subtitle    String
  category    String
  date        String
  tags        String[]
  spineColor  String
  coverColor  String
  spineText   String
  github      String?
  demoUrl     String?
  stats       Json?
  phases      Json?
  markdown    String

  @@map("projects")
  @@schema("public")
}